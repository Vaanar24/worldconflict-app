# Create .gitignore file
@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
.env
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Frontend build
frontend/build/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Backend
backend/__pycache__/
backend/.env
*.log
*.sqlite
*.db

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Misc
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db
"@ | Out-File -FilePath .gitignore -Encoding UTF8