# Create .gitignore file
@"
# Python
__pycache__/
*.py[cod]
*.so
.Python
venv/
env/
.venv
.env
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log*
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
.DS_Store

# Frontend build
frontend/build/
frontend/.env.local

# Backend
backend/__pycache__/
backend/.env

# Logs
*.log
"@ | Out-File -FilePath .gitignore -Encoding UTF8

# Add and commit .gitignore
git add .gitignore
git commit -m "Add .gitignore to exclude unnecessary files"
git push origin main